rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{trip} {
      // the allowed-email list lives in Firestore (config/allowlist), not in this
      // file, so personal emails never appear in the public repo
      function allowedEmails() {
        return get(/databases/$(database)/documents/trips/$(trip)/config/allowlist).data.emails;
      }
      function isAllowed() {
        return request.auth != null
          && request.auth.token.get('email_verified', false) == true
          && request.auth.token.get('email', '').lower() in allowedEmails();
      }
      function rosterExists() {
        return exists(/databases/$(database)/documents/trips/$(trip)/roster/list);
      }
      function members() {
        return get(/databases/$(database)/documents/trips/$(trip)/roster/list).data.members;
      }
      function isMember() {
        return isAllowed() && rosterExists() && request.auth.uid in members();
      }

      // private trip config — allowlist is server-managed only (rules read it via
      // get(), which doesn't require client read access); itinerary holds flight
      // confirmations and hotel details, readable only by allowed accounts
      match /config/allowlist {
        allow read, write: if false;
      }
      match /config/itinerary {
        allow read: if isAllowed();
        allow write: if false;
      }

      // roster: readable by members; an allowed user may add ONLY themselves, capped at 13
      match /roster/list {
        allow read: if isMember();
        allow create: if isAllowed()
          && request.resource.data.members.size() <= 13
          && request.resource.data.members.keys().hasOnly([request.auth.uid]);
        allow update: if isAllowed()
          && request.resource.data.members.size() <= 13
          && request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid]);
      }

      // shared IOU ledger — members only
      match /ledger/{entry} {
        allow read, write: if isMember();
      }

      // pins — members read all; you write only your own doc
      match /pins/{uid} {
        allow read: if isMember();
        allow write: if request.auth != null && request.auth.uid == uid && isMember();
      }

      // clan-added items — members read; any member may add one as themselves;
      // only the person who added an item may change or remove it
      match /items/{item} {
        allow read: if isMember();
        allow create: if isMember() && request.resource.data.byUid == request.auth.uid;
        allow update, delete: if isMember() && resource.data.byUid == request.auth.uid;
      }
    }
  }
}
